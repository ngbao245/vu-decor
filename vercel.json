{
  "redirects": [
    {
      "source": "/hubibo",
      "destination": "/hubibo/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/hubibo",
      "destination": "https://note-silk-gamma.vercel.app/hubibo"
    },
    {
      "source": "/hubibo/:match*",
      "destination": "https://note-silk-gamma.vercel.app/hubibo/:match*"
    },
    {
      "source": "/((?!hubibo).*)",
      "destination": "/index.html"
    }
  ]
}
