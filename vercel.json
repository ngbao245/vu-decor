{
  "redirects": [
    {
      "source": "/snotes",
      "destination": "/snotes/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/notes",
      "destination": "https://note-silk-gamma.vercel.app"
    },
    {
      "source": "/notes/:path*",
      "destination": "https://note-silk-gamma.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
