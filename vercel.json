{
  "rewrites": [
    {
      "source": "/hubibo",
      "destination": "https://note-silk-gamma.vercel.app/"
    },
    {
      "source": "/hubibo/:match*",
      "destination": "https://note-silk-gamma.vercel.app/:match*"
    },
    {
      "source": "/((?!hubibo).*)",
      "destination": "/index.html"
    }
  ]
}
